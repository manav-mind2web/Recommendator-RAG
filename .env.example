# ---- Chat provider selection ----
# Which LLM provider the chat endpoint uses: "anthropic", "openai", or "google".
PROVIDER=anthropic

# ---- Anthropic (used when PROVIDER=anthropic) ----
ANTHROPIC_API_KEY=
# Optional override. Defaults to claude-opus-4-8.
# For a cheaper run on this tiny dataset, try: claude-haiku-4-5
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Google / Gemini (used when PROVIDER=google) ----
# The AI SDK reads this env var name by default.
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional override. Defaults to gemini-2.5-flash.
GOOGLE_MODEL=gemini-2.5-flash

# ---- OpenAI (used when PROVIDER=openai for chat) ----
OPENAI_API_KEY=
# Optional override. Defaults to gpt-4o.
OPENAI_MODEL=gpt-4o

# ---- Embeddings (semantic search) ----
# Decoupled from the chat provider. Two backends:
#   local  (default) — on-device via Transformers.js. No API key, no network at
#                      query time once the model is cached. 384-dim.
#   openai           — text-embedding-3-small (1536-dim). Requires OPENAI_API_KEY.
# NOTE: changing this changes the vector dimension, so re-run `npm run seed`.
EMBEDDING_PROVIDER=local
# Optional override for the local model. Defaults to Xenova/all-MiniLM-L6-v2.
LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
# Optional override for the OpenAI model. Defaults to text-embedding-3-small (1536 dims).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Postgres + pgvector (matches docker-compose.yml) ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/listings
